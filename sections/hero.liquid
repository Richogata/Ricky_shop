<section class="hero">
  <div class="hero-content">
    <p class="hero-kicker">{{ section.settings.kicker }}</p>
    <h1>{{ section.settings.title }}</h1>
    <p>{{ section.settings.description }}</p>
    {% if section.settings.button_label != blank %}
      <a class="btn" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">{{ section.settings.button_label }}</a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "NOUVELLE SAISON" },
    { "type": "text", "id": "title", "label": "Titre", "default": "Ricky_shop" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Une sélection premium pour un style et un confort sans compromis." },
    { "type": "text", "id": "button_label", "label": "Texte du bouton", "default": "Voir la collection" },
    { "type": "url", "id": "button_link", "label": "Lien du bouton" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
